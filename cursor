IF OBJECT_ID('tb_pedidos') IS NULL
CREATE TABLE tb_pedidos (
    pedido_id VARCHAR(20),
    cliente_id VARCHAR(50),
    total_pedido DECIMAL(10,2)
);

IF OBJECT_ID('tb_itens') IS NULL
CREATE TABLE tb_itens (
    pedido_id VARCHAR(20),
    sku VARCHAR(50),
    produto VARCHAR(100),
    qtd INT,
    preco DECIMAL(10,2)
);

IF OBJECT_ID('tb_envio') IS NULL
CREATE TABLE tb_envio (
    pedido_id VARCHAR(20)
);

IF OBJECT_ID('tb_estoque') IS NULL
CREATE TABLE tb_estoque (
    sku VARCHAR(50),
    disponivel INT
);

TRUNCATE TABLE tb_envio;
TRUNCATE TABLE tb_itens;
TRUNCATE TABLE tb_pedidos;
TRUNCATE TABLE tb_estoque;

IF OBJECT_ID('tempdb..#base') IS NOT NULL DROP TABLE #base;
IF OBJECT_ID('tempdb..#calc') IS NOT NULL DROP TABLE #calc;
IF OBJECT_ID('tempdb..#prioridade') IS NOT NULL DROP TABLE #prioridade;

CREATE TABLE #base (
    pedido_id VARCHAR(20),
    data DATE,
    sku VARCHAR(50),
    upc VARCHAR(50),
    descricao VARCHAR(100),
    quantidade INT,
    preco_txt VARCHAR(20),
    frete_txt VARCHAR(20),
    email VARCHAR(100),
    cliente_id VARCHAR(50),
    nome VARCHAR(100),
    endereco VARCHAR(100),
    cep VARCHAR(20),
    uf VARCHAR(10),
    pais VARCHAR(50)
);

BULK INSERT #base
FROM 'C:\temp\pedidos.txt'
WITH (
    FIRSTROW = 2,
    FIELDTERMINATOR = ';',
    ROWTERMINATOR = '0x0a',
    CODEPAGE = '65001'
);

SELECT
    pedido_id,
    SUM(CAST(REPLACE(preco_txt, ',', '.') AS DECIMAL(10,2)) * quantidade)
    + MAX(CAST(REPLACE(frete_txt, ',', '.') AS DECIMAL(10,2))) AS total
INTO #calc
FROM #base
GROUP BY pedido_id;

SELECT
    pedido_id,
    total,
    ROW_NUMBER() OVER (ORDER BY total DESC) AS prioridade
INTO #prioridade
FROM #calc;

INSERT INTO tb_pedidos (pedido_id, cliente_id, total_pedido)
SELECT
    b.pedido_id,
    MAX(b.cliente_id),
    c.total
FROM #base b
INNER JOIN #calc c ON c.pedido_id = b.pedido_id
GROUP BY b.pedido_id, c.total;

INSERT INTO tb_itens (pedido_id, sku, produto, qtd, preco)
SELECT
    pedido_id,
    sku,
    descricao,
    quantidade,
    CAST(REPLACE(preco_txt, ',', '.') AS DECIMAL(10,2))
FROM #base;

INSERT INTO tb_estoque (sku, disponivel)
SELECT
    sku,
    SUM(quantidade) * 2
FROM #base
GROUP BY sku;

DECLARE @pedidoAtual VARCHAR(20);

DECLARE c_loop CURSOR FOR
SELECT pedido_id
FROM #prioridade
ORDER BY prioridade;

OPEN c_loop;
FETCH NEXT FROM c_loop INTO @pedidoAtual;

WHILE @@FETCH_STATUS = 0
BEGIN
    IF NOT EXISTS (
        SELECT 1
        FROM tb_itens i
        JOIN tb_estoque e ON e.sku = i.sku
        WHERE i.pedido_id = @pedidoAtual
        AND i.qtd > e.disponivel
    )
    BEGIN
        INSERT INTO tb_envio (pedido_id)
        VALUES (@pedidoAtual);

        UPDATE e
        SET e.disponivel = e.disponivel - i.qtd
        FROM tb_estoque e
        JOIN tb_itens i ON i.sku = e.sku
        WHERE i.pedido_id = @pedidoAtual;
    END

    FETCH NEXT FROM c_loop INTO @pedidoAtual;
END

CLOSE c_loop;
DEALLOCATE c_loop;

SELECT * FROM tb_envio;
SELECT * FROM tb_estoque;
SELECT * FROM #prioridade ORDER BY prioridade;
